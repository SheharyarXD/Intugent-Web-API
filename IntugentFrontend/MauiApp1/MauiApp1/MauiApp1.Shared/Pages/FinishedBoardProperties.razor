        3 => data?.GCompStrFGRetest_3 ?? "",
        4 => data?.GCompStrFGRetest_4 ?? "",
        5 => data?.GCompStrFGRetest_5 ?? "",
        6 => data?.GCompStrFGRetest_6 ?? "",
