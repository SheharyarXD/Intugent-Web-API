        3 => data?.GKFactor90Date_3,
        _ => null
    };

    private string GetKFactor180Value(int i) => i switch
    {
        1 => data?.GkFactor180_1 ?? "",
        2 => data?.GkFactor180_2 ?? "",
        3 => data?.GkFactor180_3 ?? "",
        _ => ""
    };

    private DateTime? GetKFactor180Date(int i) => i switch
    {
        1 => data?.GKFactor180Date_1,
        2 => data?.GKFactor180Date_2,
        3 => data?.GKFactor180Date_3,
        _ => null
    };

    private string GetLocLabel(int idx, string suffix) => idx switch
    {
        1 => (suffix == "A" ? data?.GLoc1A : suffix == "B" ? data?.GLoc1B : suffix == "C" ? data?.GLoc1C : suffix == "D" ? data?.GLoc1D : data?.GLoc1E) ?? "",
        2 => (suffix == "A" ? data?.GLoc2A : suffix == "B" ? data?.GLoc2B : suffix == "C" ? data?.GLoc2C : suffix == "D" ? data?.GLoc2D : data?.GLoc2E) ?? "",
        3 => (suffix == "A" ? data?.GLoc3A : suffix == "B" ? data?.GLoc3B : suffix == "C" ? data?.GLoc3C : suffix == "D" ? data?.GLoc3D : data?.GLoc3E) ?? "",
        _ => ""
    };

    private string GetCoreMass(int r) => r switch { 1 => data?.GMass1 ?? "", 2 => data?.GMass2 ?? "", 3 => data?.GMass3 ?? "", _ => "" };
    private string GetCoreL1(int r) => r switch { 1 => data?.GL1_1 ?? "", 2 => data?.GL1_2 ?? "", 3 => data?.GL1_3 ?? "", _ => "" };
    private string GetCoreW1(int r) => r switch { 1 => data?.GW1_1 ?? "", 2 => data?.GW1_2 ?? "", 3 => data?.GW1_3 ?? "", _ => "" };
    private string GetCoreT(int r, int t) => (r, t) switch
    {
        (1, 1) => data?.GT1_1 ?? "",
        (1, 2) => data?.GT2_1 ?? "",
        (1, 3) => data?.GT3_1 ?? "",
        (1, 4) => data?.GT4_1 ?? "",
        (1, 5) => data?.GT5_1 ?? "",
        (2, 1) => data?.GT1_2 ?? "",
        (2, 2) => data?.GT2_2 ?? "",
        (2, 3) => data?.GT3_2 ?? "",
        (2, 4) => data?.GT4_2 ?? "",
        (2, 5) => data?.GT5_2 ?? "",
        (3, 1) => data?.GT1_3 ?? "",
        (3, 2) => data?.GT2_3 ?? "",
        (3, 3) => data?.GT3_3 ?? "",
        (3, 4) => data?.GT4_3 ?? "",
        (3, 5) => data?.GT5_3 ?? "",
        _ => ""
    };
    private bool GetCoreKnit(int r) => r switch { 1 => data?.GCoreDensKnitLine1 ?? false, 2 => data?.GCoreDensKnitLine2 ?? false, 3 => data?.GCoreDensKnitLine3 ?? false, _ => false };
    private string GetCoreDens(int r) => r switch { 1 => data?.GCoreDens1 ?? "", 2 => data?.GCoreDens2 ?? "", 3 => data?.GCoreDens3 ?? "", _ => "" };
    private bool GetCoreDensBackground(int r) => r switch
    {
        1 => data?.GCoreDens1Background ?? true,
        2 => data?.GCoreDens2Background ?? true,
