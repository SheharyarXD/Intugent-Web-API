@page "/"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Intugent PI - Session Selection</PageTitle>

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
</div>

<div class="row">
    <div class="col-lg-12 mt-5 d-flex justify-content-center align-items-center">

        <!-- Group Selection Card -->
        <div class="card card-default col-6">
            <div class="card-header align-items-center">
                <h2>Choose the User Group</h2>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-12">
                        <!-- Group Dropdown -->
                        <div class="form-floating mb-3">
                            <select id="gGroups" class="form-select" @bind="selectedGroupIndex">
                                <option value="0">-- Select a Group --</option>
                                @if (groups != null)
                                {
                                    @for (int i = 0; i < groups.Count; i++)
                                    {
                                        <option value="@(i + 1)">@groups[i]</option>
                                    }
                                }
                            </select>
                            <label for="gGroups">Groups</label>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="col-lg-12">
                            <div class="alert alert-danger" role="alert">
                                @errorMessage
                            </div>
                        </div>
                    }

                    @if (isLoading)
                    {
                        <div class="col-lg-12 text-center">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    }

                    <div class="col-lg-12 d-flex justify-content-end">
                        <button type="button"
                                class="btn btn-primary"
                                @onclick="BeginSession"
                                disabled="@(selectedGroupIndex == 0 || isLoading)">
                            Begin the Intugent PI Session
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<string>? groups;
    private int selectedGroupIndex = 0;
    private string? errorMessage;
    private bool isLoading = false;

    // Base API URL - adjust for your environment
    private const string ApiBaseUrl = "https://localhost:44323/api";

    protected override async Task OnInitializedAsync()
    {
        await LoadGroups();
    }

    private async Task LoadGroups()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            // Try to get groups from API
            var response = await Http.GetFromJsonAsync<List<string>>($"{ApiBaseUrl}/Session/groups");

            if (response != null)
            {
                groups = response;
            }
            else
            {
                // Fallback to hardcoded groups if API fails
                groups = new List<string>
                {
                    "OKTA_GAF_Intugent_RnD_Users",
                    "OKTA_GAF_Intugent_Mfg_Users_Gainesville",
                    "OKTA_GAF_Intugent_Mfg_Uses_Stratesboro",
                    "OKTA_GAF_Intugent_Mfg_Users_CedarCity",
                    "OKTA_GAF_Intugent_Mfg_Users_NewColumbia",
                    "OKTA_GAF_Intugent_Admins"
                };
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load groups: {ex.Message}";
            // Fallback
            groups = new List<string>
            {
                "OKTA_GAF_Intugent_RnD_Users",
                "OKTA_GAF_Intugent_Mfg_Users_Gainesville",
                "OKTA_GAF_Intugent_Mfg_Uses_Stratesboro",
                "OKTA_GAF_Intugent_Mfg_Users_CedarCity",
                "OKTA_GAF_Intugent_Mfg_Users_NewColumbia",
                "OKTA_GAF_Intugent_Admins"
            };
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BeginSession()
    {
        if (selectedGroupIndex <= 0 || groups == null || selectedGroupIndex > groups.Count)
        {
            errorMessage = "Please select a valid group.";
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = null;

            var request = new { UserId = selectedGroupIndex };

            var response = await Http.PostAsJsonAsync($"{ApiBaseUrl}/Session/begin", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BeginSessionResponse>();

                // Store in local storage or state
                await JS.InvokeVoidAsync("localStorage.setItem", "userId", selectedGroupIndex.ToString());

                // Navigate to main app page
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Server error: {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to begin session: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class BeginSessionResponse
    {
        public int UserId { get; set; }
        public string Message { get; set; } = string.Empty;
    }
}