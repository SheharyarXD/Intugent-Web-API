    private string GetFacerPeelValue(int i) => i switch { 1 => data?.GFacerPeel1 ?? "", 2 => data?.GFacerPeel2 ?? "", 3 => data?.GFacerPeel3 ?? "", _ => "" };
    private string GetNailPullValue(int i) => i switch { 1 => data?.GNailPull_1 ?? "", 2 => data?.GNailPull_2 ?? "", 3 => data?.GNailPull_3 ?? "", _ => "" };

    // Response wrapper
    public class ApiResponse
    {
        public bool success { get; set; }
        public object? data { get; set; }
        public string? error { get; set; }
    }
}
