    private bool GetCompStrRetestKnit(int i) => i switch
    {
        1 => data?.GCompStrFGKnitRetest_1 ?? false,
        2 => data?.GCompStrFGKnitRetest_2 ?? false,
        3 => data?.GCompStrFGKnitRetest_3 ?? false,
        4 => data?.GCompStrFGKnitRetest_4 ?? false,
        5 => data?.GCompStrFGKnitRetest_5 ?? false,
        6 => data?.GCompStrFGKnitRetest_6 ?? false,
        _ => false
    };

    private string GetKFactorValue(int i) => i switch
    {
        1 => data?.GkFactor_1 ?? "",
        2 => data?.GkFactor_2 ?? "",
        3 => data?.GkFactor_3 ?? "",
        _ => ""
    };

    private DateTime? GetKFactorTime(int i) => i switch
    {
        1 => data?.GkFactorTime1,
        2 => data?.GkFactorTime2,
        3 => data?.GkFactorTime3,
        _ => null
    };

    private bool GetRValueKnit(int i) => i switch
    {
        1 => data?.GRValueKnitPresent1 ?? false,
        2 => data?.GRValueKnitPresent2 ?? false,
